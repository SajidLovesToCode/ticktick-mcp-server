{
  "name": "ticktick-mcp-server",
  "version": "0.2.0",
  "description": "TickTick Model Context Protocol Server for Claude",
  "private": true,
  "type": "module",
  "bin": {
    "ticktick-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:auth": "npm run build && node dist/index.js auth",
    "dev": "npm run build && npm run start",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "axios": "^1.6.0",
    "conf": "^12.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.0",
    "express": "^5.2.1",
    "open": "^10.0.0",
    "simple-oauth2": "^5.1.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.24",
    "@types/simple-oauth2": "^5.0.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ticktick",
    "tasks",
    "productivity",
    "claude",
    "ai"
  ],
  "author": "Hiroki TSUTSUMI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsutsuhiro/ticktick-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/tsutsuhiro/ticktick-mcp-server/issues"
  },
  "homepage": "https://github.com/tsutsuhiro/ticktick-mcp-server#readme",
  "license": "MIT"
}
