{
  "name": "ticktick-mcp-server",
  "version": "0.1.0",
  "description": "TickTick Model Context Protocol Server for Claude",
  "private": true,
  "type": "module",
  "bin": {
    "ticktick-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "npm run build && npm run start",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "axios": "^1.6.0",
    "conf": "^12.0.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.0",
    "keytar": "^7.9.0",
    "open": "^10.0.0",
    "simple-oauth2": "^5.1.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/jest": "^29.0.0",
    "@types/keytar": "^4.4.0",
    "@types/node": "^20.11.24",
    "@types/simple-oauth2": "^5.0.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ticktick",
    "tasks",
    "productivity",
    "claude",
    "ai"
  ],
  "author": "Your Name",
  "license": "MIT"
}
